{
  "name": "@lovelace_lol/embody",
  "version": "0.0.0",
  "description": "Renderer-agnostic character animation runtime for facial AUs, visemes, and bone-driven motion",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./three": {
      "types": "./dist/three.d.ts",
      "import": "./dist/three.js",
      "require": "./dist/three.cjs"
    },
    "./cljs": {
      "types": "./dist/cljs.d.ts",
      "import": "./dist/cljs.js",
      "require": "./dist/cljs.cjs"
    },
    "./wasm": {
      "types": "./dist/wasm.d.ts",
      "import": "./dist/wasm.js",
      "require": "./dist/wasm.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && npm run wasm:build",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:exports": "npm run build && node scripts/smoke/package-exports.mjs",
    "test:pack": "npm run build && npm pack --dry-run",
    "bench:runtime": "npm run build && node scripts/bench/runtime.mjs",
    "rust:test": "RUSTC=$(rustup which rustc) RUSTDOC=$(rustup which rustdoc) rustup run stable cargo test --manifest-path rust/embody-wasm/Cargo.toml",
    "rust:wasm-build": "RUSTC=$(rustup which rustc) RUSTDOC=$(rustup which rustdoc) rustup run stable cargo build --manifest-path rust/embody-wasm/Cargo.toml --target wasm32-unknown-unknown --release",
    "wasm:build": "node scripts/build-wasm.mjs",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "three": ">=0.150.0"
  },
  "devDependencies": {
    "@types/three": "^0.170.0",
    "@vitest/coverage-v8": "^3.2.4",
    "three": "^0.170.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.4",
    "wasm-pack": "^0.15.0"
  },
  "keywords": [
    "3d",
    "animation",
    "facial-animation",
    "FACS",
    "action-units",
    "visemes",
    "lip-sync",
    "character-animation",
    "morph-targets",
    "blendshapes",
    "three.js",
    "babylon.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meekmachine/embody.git"
  },
  "bugs": {
    "url": "https://github.com/meekmachine/embody/issues"
  },
  "homepage": "https://github.com/meekmachine/embody#readme",
  "author": "Jonathan Sutton Fields",
  "license": "MIT",
  "packageManager": "npm@10.9.2"
}
